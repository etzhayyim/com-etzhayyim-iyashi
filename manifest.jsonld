  "@type": "ActorManifest",
  "id": "did:web:iyashi.etzhayyim.com",
  "name": "iyashi",
  "displayName": "癒 — Clinical Care Provider",
  "displayNameJa": "癒",
  "displayNameEn": "Iyashi",
  "description": "Non-profit religious-corp clinical care provider substrate. Community-clinic-model primary care + chronic followup + vaccination + acute first-line + maternity/pediatric clinical. Encrypted PHI envelope MANDATORY (G2 per ADR-2605181100). NO commercial EHR (G11; Epic/Cerner/Athena/Allscripts/NextGen/eClinicalWorks/Greenway/Practice Fusion PROHIBITED per Charter Rider §2(e)+§2(c)). NO insurance billing (G13; funded via Public Fund grant + sliding-scale donation). NO payroll for providers (G14; vocation-flow L5 stewards). Murakumo-only inference (G12). NO video recording firmware-level (G3). Human-in-loop ALWAYS (G8). 6 cells / 6 Lexicons / 14 gates / 12 non-goals. Cross-actor: mitate (diagnosis) / hagukumi (daily-living) / yakushi (medication) / toritate (funding) / chigiri (consent + procedural) / manabi (provider CME) / kokoro (mental health, future).",
  "descriptionJa": "非営利 religious-corp の臨床ケア提供 substrate。地域診療所モデル の プライマリケア + 慢性ケア継続 + 予防接種 + 急性期初期対応 + 母子保健。暗号化エンベロープ必須 (G2)。商業 EHR 禁止 (G11: Epic / Cerner / Athena / Allscripts / NextGen / eClinicalWorks / Greenway / Practice Fusion PROHIBITED per Charter Rider §2(e)+§2(c))。保険請求自動化なし (G13; Public Fund grant + sliding-scale donation で運営)。給与なし (G14; provider は L5 vocation-flow steward)。Murakumo only inference (G12)。ビデオ録画ファームウェアレベル禁止 (G3)。human-in-loop 必須 (G8)。",
  "adr": {
    "master": "etzhayyim:adr:2605263000",
    "parent": "etzhayyim:adr:2605261000",
    "r0": "etzhayyim:adr:2605263000",
    "r1": "reserved",
    "r2": "reserved",
    "r3": "reserved"
  },
  "tier": "Tier-B",
  "parentActor": null,
  "liberationLadderGate": "L4",
  "siblingsAtL4": [
    "did:web:yakushi.etzhayyim.com (pharmaceutical manufacturing)",
    "did:web:mitate.etzhayyim.com (diagnostic routing)",
    "did:web:hagukumi.etzhayyim.com (daily-living care)"
  ],
  "crossActorPair": {
    "mitate": "diagnosis ↔ clinical encounter; mitate's G5 emergency keyword shared (G10)",
    "hagukumi": "daily-living care continuity; chronic_care_followup pairs with hagukumi.chronic_continuity",
    "yakushi": "Sukoyaka cold-chain medication delivery (vaccination + prescription)",
    "toritate": "donation + Public Fund grant accounting (read)",
    "chigiri": "consent + procedural attestation + stewardLaborAttestation L5 vocation-flow classification (read)",
    "manabi": "provider continuing-medical-education curriculum delivery + tracking",
    "kokoro": "mental health cross-link (future actor; postnatal mood screening / chronic mental health continuity)"
  },
  "form": "任意団体 internal clinical care provider substrate (NOT 一般社団 / NPO / 公益財団 / 宗教法人 法人格 — Preamble §0.4 Lv7+ unanimity lock)",
  "privacyInvariant": {
    "encryptedEnvelope": "MANDATORY per ADR-2605181100; structural Lexicon enforcement at R1 (clinicalEncounterAttestation + chronicCareContinuityRecord MUST carry encryptedPayloadCid; additionalProperties=false at top-level)",
    "videoRecording": "PROHIBITED firmware-level (G3) — live telepresence permitted, frame-write-to-disk PROHIBITED",
    "humanInLoop": "ALWAYS — no AI-only clinical decision; AI-assist requires synchronous provider sign-off (G8)",
    "rationale": "Clinical PHI is the most sensitive observation class in religious-corp; structural privacy enforcement, not policy."
  },
  "constitutionalDiscipline": {
    "noStateLicensedEntity": "Religious-corp itself is NOT a state-licensed medical entity; individual providers carry state license per jurisdiction; iyashi is procedural + attestation substrate, NOT licensed clinic (UPL analog to chigiri G14)",
    "noCommercialEHR": "G11 — Epic / Cerner / Athena / Allscripts / NextGen / eClinicalWorks / Greenway / Practice Fusion PROHIBITED (Charter Rider §2(e) anti-gatekeeping + §2(c) vendor data-sovereignty exposes patient + provider posture)",
    "noInsuranceBilling": "G13 — funded via Public Fund grant + sliding-scale donation only; state insurance integration OUT OF SCOPE at all phases (requires 宗教法人法 登記 which is constitutionally excluded per Preamble §0.4)",
    "noPayrollForProviders": "G14 — providers are vocation-flow L5 stewards per Liberation Ladder L0..L6 (ADR-2605261000 + ADR-2605262700 G13 + ADR-2605262900 G12); toritate.ledgerEntry.category enum excludes payroll/wage/salary/bonus/commission",
    "muragumoOnlyInference": "G12 — Murakumo-only inference per ADR-2605215000; vendor clinical-AI (Microsoft Nuance DAX / Abridge / Suki AI / Augmedix) PROHIBITED"
  },
  "scope": {
    "phase": "R0 scaffold",
    "scopeBoundary": "Community-clinic-model clinical encounter provision (primary care + chronic followup + vaccination + acute first-line + maternity/pediatric clinical + provider lifecycle + facility standards)",
    "exclusions": [
      "pharmaceutical manufacturing (yakushi domain)",
      "diagnostic AI routing (mitate domain)",
      "daily-living care (hagukumi domain)",
      "hospice / palliative terminal (specialist actor TBD)",
      "surgery beyond minor procedures (hospital referral)",
      "behavioral psych intervention (kokoro future actor)",
      "telemedicine as substitute for in-person",
      "insurance / fee-for-service medicine",
      "commercial EHR integration (Epic / Cerner / Athena / etc. PROHIBITED)",
      "state-licensed medical entity status (individual providers carry license; iyashi does not)",
      "provider-credentialing certificate authority (providerAttestation = vetting + Council attestation, NOT issued credential)",
      "in-home surveillance (cameras / audio / location / biometric monitoring)"
    ]
  },
  "cells": [
