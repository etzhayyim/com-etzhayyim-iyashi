  "constitutionalGates": {
    "description": "14 immutable gates per ADR-2605263000. Council Lv6+ supermajority + new ADR to amend.",
    "gates": {
      "G1": "Charter Rider §2(a)-(h) scan on every clinical document",
      "G2": "Encrypted envelope MANDATORY per ADR-2605181100; plaintext content fields rejected at schema layer (R1 additionalProperties=false)",
      "G3": "No video recording (firmware-level enforcement)",
      "G4": "Per-encounter consent (default-deny)",
      "G5": "Provider Council vetting: medical-license-cite-CID + Council Lv6+ ≥3 attestation + ≥1 licensed-MD on Council medical advisory",
      "G6": "No advertising / no commercial-product promotion in care setting",
      "G7": "No behavioral modification protocols",
      "G8": "Human-in-loop ALWAYS for AI-assisted clinical decision support (no AI-only)",
      "G9": "Provider 12-hr work cap + 12-hr recovery between shifts",
      "G10": "Emergency escalation to mitate via shared emergency keyword lexicon",
      "G11": "NO commercial EHR (Epic / Cerner / Athena / Allscripts / NextGen / eClinicalWorks / Greenway / Practice Fusion PROHIBITED)",
      "G12": "Murakumo-only inference (no vendor clinical-AI)",
      "G13": "NO insurance billing automation (Public Fund grant + sliding-scale donation only)",
      "G14": "NO payroll for providers (vocation-flow L5 stewards)"
    }
  },
  "nonGoals": {
    "description": "12 explicitly excluded scopes",
    "goals": {
      "N1": "NOT pharmaceutical manufacturing (yakushi)",
      "N2": "NOT diagnostic AI routing (mitate)",
      "N3": "NOT daily-living care (hagukumi)",
      "N4": "NOT hospice/palliative terminal",
      "N5": "NOT surgical (beyond minor procedures — hospital referral)",
      "N6": "NOT behavioral psych intervention (kokoro future)",
      "N7": "NOT telemedicine substitute for in-person",
      "N8": "NOT insurance / fee-for-service medicine",
      "N9": "NOT commercial EHR integrator",
      "N10": "NOT state-licensed medical entity",
      "N11": "NOT provider-credentialing certificate authority",
      "N12": "NOT in-home surveillance"
    }
  },
